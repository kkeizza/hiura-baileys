{
    "name": "hiura-baileys",
    "type": "module",
    "version": "1.5.1",
    "description": "WhatsApp Web API — Hiura Baileys by Nimzz. Full LID+JID, all buttons, interactive messages, rich messages, album, latex, and more.",
    "keywords": [
        "automation",
        "baileys",
        "baileys-fork",
        "baileys-mod",
        "interactive-messages",
        "js-whatsapp",
        "multi-device",
        "wabot",
        "botwa",
        "whatsapp",
        "whatsapp-api",
        "whatsapp-bot",
        "whatsapp-chat",
        "whatsapp-group",
        "whatsapp-web"
    ],
    "homepage": "https://github.com/Nimzz-pemboy/hiura-baileys",
    "repository": {
        "type": "git",
        "url": "https://github.com/Nimzz-pemboy/hiura-baileys.git"
    },
    "license": "MIT",
    "author": "Nimzz <https://github.com/Nimzz-pemboy>",
    "main": "./index.cjs",
    "module": "./lib/index.js",
    "types": "./index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./lib/index.d.ts",
                "default": "./lib/index.js"
            },
            "require": {
                "types": "./index.d.ts",
                "default": "./index.cjs"
            },
            "default": "./lib/index.js"
        }
    },
    "files": [
        "lib/**/*",
        "WAProto/**/*",
        "engine-requirements.js",
        "index.cjs",
        "index.d.ts",
        "README.md"
    ],
    "dependencies": {
        "@cacheable/node-cache": "^1.4.0",
        "@hapi/boom": "^9.1.3",
        "async-mutex": "^0.5.0",
        "audio-decode": "^3.0.0",
        "axios": "^1.13.6",
        "cache-manager": "^5.7.6",
        "chalk": "^5.3.0",
        "cheerio": "^1.2.0",
        "fflate": "^0.8.2",
        "gradient-string": "^3.0.0",
        "libsignal": "git+https://github.com/whiskeysockets/libsignal-node",
        "lru-cache": "^11.1.0",
        "music-metadata": "^11.7.0",
        "p-queue": "^9.0.0",
        "pino": "^9.6",
        "protobufjs": "^7.2.4",
        "whatsapp-rust-bridge": "0.5.2",
        "ws": "^8.13.0"
    },
    "peerDependencies": {
        "jimp": "^1.6.0",
        "link-preview-js": "^3.0.0",
        "sharp": "*"
    },
    "peerDependenciesMeta": {
        "jimp": {
            "optional": true
        },
        "link-preview-js": {
            "optional": true
        }
    },
    "packageManager": "yarn@4.9.2",
    "engines": {
        "node": ">=20.19.0 <21.0.0 || >=22.12.0"
    }
}

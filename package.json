{
    "name": "hiura-baileys",
    "version": "1.0.1",
    "description": "WhatsApp Web API — Hiura Baileys by Nimzz. Full LID+JID support, all buttons, dual CJS/ESM.",
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "whatsapp",
        "hiura",
        "hiura-baileys",
        "nimzz",
        "whatsapp-api",
        "whatsapp-bot",
        "baileys",
        "automation",
        "messaging",
        "lid",
        "button"
    ],
    "homepage": "https://github.com/Nimzz-pemboy/hiura-baileys",
    "repository": {
        "type": "git",
        "url": "https://github.com/Nimzz-pemboy/hiura-baileys.git"
    },
    "bugs": {
        "url": "https://github.com/Nimzz-pemboy/hiura-baileys/issues"
    },
    "license": "MIT",
    "author": "Nimzz <https://github.com/Nimzz-pemboy>",
    "main": "lib/index.js",
    "module": "esm/index.mjs",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "require": "./lib/index.js",
            "import": "./esm/index.mjs",
            "default": "./lib/index.js"
        },
        "./MessageBuilder": {
            "require": "./MessageBuilder.js",
            "import": "./esm/MessageBuilder.mjs",
            "default": "./MessageBuilder.js"
        }
    },
    "files": [
        "lib/**/*",
        "esm/**/*",
        "WAProto/**/*",
        "MessageBuilder.js",
        "engine-requirements.js",
        "README.md"
    ],
    "scripts": {
        "build:esm": "node scripts/build-esm.js",
        "test": "jest",
        "lint": "eslint lib --ext .js"
    },
    "dependencies": {
        "@adiwajshing/keyed-db": "^0.2.4",
        "@cacheable/node-cache": "^1.4.0",
        "@hapi/boom": "^9.1.3",
        "async-mutex": "^0.5.0",
        "audio-decode": "^2.1.3",
        "axios": "^1.3.3",
        "cache-manager": "4.0.1",
        "chalk": "^4.1.2",
        "futoin-hkdf": "^1.5.1",
        "libphonenumber-js": "^1.10.20",
        "libsignal": "npm:hiura-libsignal@^1.0.0",
        "lodash": "^4.17.21",
        "music-metadata": "^7.12.3",
        "node-cache": "^5.1.2",
        "node-fetch": "^2.6.1",
        "pino": "^7.0.0",
        "protobufjs": "^7.2.4",
        "uuid": "^9.0.0",
        "ws": "^8.13.0"
    },
    "peerDependencies": {
        "jimp": "^0.16.1",
        "link-preview-js": "^3.0.0",
        "qrcode-terminal": "^0.12.0",
        "sharp": "^0.32.2"
    },
    "peerDependenciesMeta": {
        "jimp": {
            "optional": true
        },
        "link-preview-js": {
            "optional": true
        },
        "qrcode-terminal": {
            "optional": true
        },
        "sharp": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "packageManager": "yarn@1.22.19"
}
